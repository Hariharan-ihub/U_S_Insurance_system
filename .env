# HealthGuard Insurance Portal — Environment Variables

# === Public (exposed to browser — VITE_ prefixed) ===
VITE_APP_NAME=HealthGuard Insurance Portal

# Auth Workflow URLs (replace with deployed Workbench webhook URLs)
VITE_AUTH_LOGIN_URL=/webhook/auth/opaque/login
VITE_AUTH_REFRESH_URL=/webhook/webhook/auth/refresh
VITE_AUTH_LOGOUT_URL=/webhook/webhook/auth/logout
VITE_AUTH_VERIFY_URL=/webhook/webhook/auth/verify

# Data Workflow URLs
VITE_DASHBOARD_URL=/webhook/member/dashboard
VITE_SESSION_URL=/webhook/session
VITE_POLICY_URL=/webhook/member/policy
VITE_CLAIMS_URL=/webhook/member/claims
VITE_BILLING_URL=/webhook/member/billing

# Proxy Mode: 'local' (uses local MongoDB mock in vite.config.ts) or 'live' (proxies to live Workbench)
VITE_PROXY_MODE=live

# === Secret (NOT exposed to browser — NO VITE_ prefix) ===
# These are used for migration scripts and Workbench workflow reference only
